{
  "name": "board",
  "version": "0.1.0",
  "description": "Cross-client kanban board for AI agents (MCP).",
  "mcpServers": {
    "board": { "command": "board", "args": ["mcp"] }
  },
  "hooks": {
    "PostToolUse": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post_tool_use.sh" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop.sh" } ] }
    ]
  }
}
